# Example environment variables for @wireboundlabs/cli
#
# You do NOT need a .env file in the project directory for normal use.
# Recommended: store credentials in a profile instead:
#
#   mkdir -p ~/.config/wirebound/profiles
#   cp docs/templates/profile.env.example ~/.config/wirebound/profiles/acme.env
#   export WIREBOUND_PROFILE=acme
#
# See docs/CONFIGURATION.md for the full guide.

# Default profile (optional — same as --profile)
# WIREBOUND_PROFILE=acme

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# Deprecated aliases (prefer AUTH0_MGMT_* above):
# MGMT_CLIENT_ID=
# MGMT_CLIENT_SECRET=

# --- Okta (future) ---
# OKTA_DOMAIN=
# OKTA_API_TOKEN=

# --- Azure Entra ID (future) ---
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- Transmit Security (future) ---
# TRANSMIT_TENANT_ID=
# TRANSMIT_CLIENT_ID=
# TRANSMIT_CLIENT_SECRET=
