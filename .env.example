# Example environment variables for @wireboundlabs/cli
#
# Recommended: run setup for each Auth0 environment in the repo:
#
#   wirebound setup --profile dev --default
#   wirebound setup --profile test
#   wirebound setup --profile production
#
# Profiles live in .wirebound/profiles/<name>.env (gitignored).
# See docs/CONFIGURATION.md for the full guide.

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# Optional: global profile fallback (see docs/CONFIGURATION.md)
# WIREBOUND_PROFILE=acme
