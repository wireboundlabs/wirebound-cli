{
  "name": "@wireboundlabs/cli",
  "version": "0.4.0",
  "description": "Auth0 Management API CLI — bulk user search, block & org management, tenant logs & safe cleanup from the terminal. Dry-run default, JSON for CI, multi-env profiles.",
  "keywords": [
    "auth0",
    "auth0-cli",
    "auth0-management-api",
    "cli",
    "identity",
    "idp",
    "user-management",
    "organizations",
    "tenant",
    "management-api",
    "devops",
    "automation",
    "dry-run",
    "wirebound",
    "oclif",
    "bulk-users",
    "auth0-users",
    "auth0-organizations",
    "auth0-logs"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Wirebound Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/wireboundlabs/wirebound-cli.git"
  },
  "homepage": "https://github.com/wireboundlabs/wirebound-cli#readme",
  "bugs": "https://github.com/wireboundlabs/wirebound-cli/issues",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "wirebound": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "README.md",
    ".env.example",
    "oclif.manifest.json"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -b && tsc-alias -p tsconfig.json",
    "dev": "./bin/dev.js",
    "lint": "eslint",
    "prepack": "npm run build && oclif manifest",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "pretest:coverage": "npm run build",
    "test:coverage": "c8 mocha --forbid-only \"test/**/*.test.ts\"",
    "fallow": "fallow",
    "version": "oclif readme && git add README.md"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@oclif/core": "^4",
    "bottleneck": "^2.19.5",
    "cli-progress": "^3.12.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/cli-progress": "^3.11.6",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "c8": "^11.0.0",
    "chai": "^4",
    "eslint": "^9",
    "fallow": "^2.94.0",
    "mocha": "^11",
    "nock": "^14",
    "oclif": "^4",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "typescript-eslint": "^8"
  },
  "oclif": {
    "bin": "wirebound",
    "commands": "./dist/commands",
    "dirname": "wirebound",
    "topicSeparator": " "
  }
}
